---
// Destaque.astro
const { img, title, descricao, tags = [] } = Astro.props;

// Lógica original de extração do texto (mantida, apenas isolada para limpeza)
// Tenta extrair o texto entre os H2. Se falhar, usa uma string vazia para não quebrar.
let textoDescricao = "";
try {
  const start = descricao.indexOf('<h2 id="descrição">Descrição</h2>');
  const end = descricao.indexOf('<h2 id="info">Info</h2>');

  if (start !== -1 && end !== -1) {
    textoDescricao = descricao.slice(start + 37, end - 5);
  } else {
    // Fallback caso a estrutura do markdown seja diferente
    textoDescricao = descricao.replace(/<[^>]*>?/gm, "").slice(0, 150) + "...";
  }
} catch (e) {
  textoDescricao = "Descrição indisponível.";
}
---

<div
  class="group relative rounded-2xl overflow-hidden cursor-pointer open-button h-64 md:h-80 shadow-lg hover:shadow-fab-orange/20 transition-all duration-300"
>
  <div
    class="absolute inset-0 bg-fab-orange/0 group-hover:bg-fab-orange/10 z-10 transition-colors"
  >
  </div>
  <img
    src={img}
    alt={title}
    class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700"
  />

  <div
    class="absolute inset-0 bg-gradient-to-t from-[#0a0e26] via-[#0a0e26]/80 to-transparent flex flex-col justify-end p-6"
  >
    <div
      class="transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300"
    >
      {
        tags && tags.length > 0 && (
          <div class="flex gap-2 mb-2 flex-wrap">
            {tags.slice(0, 2).map((tag, index) => (
              <span
                class={`badge text-xs border-none ${index === 0 ? "bg-fab-orange text-white" : "badge-outline text-gray-300"}`}
              >
                {tag}
              </span>
            ))}
          </div>
        )
      }

      <h3 class="text-2xl font-bold text-white mb-1">{title}</h3>

      <div
        class="text-gray-400 text-sm line-clamp-2 opacity-0 group-hover:opacity-100 transition-opacity delay-100"
        set:html={textoDescricao}
      />
    </div>
  </div>

  <dialog class="modal backdrop-blur-md p-0 bg-transparent">
    <div
      class="modal-box w-11/12 max-w-5xl bg-[#0a0e26] border border-fab-orange/30 text-white shadow-2xl shadow-fab-orange/20 p-0 overflow-hidden relative"
    >
      <button
        class="close-button btn btn-sm btn-circle btn-ghost absolute right-4 top-4 text-white hover:bg-white/10 z-50"
        >✕</button
      >

      <div class="grid grid-cols-1 lg:grid-cols-2 h-full">
        <div
          class="h-64 lg:h-auto overflow-hidden border-b lg:border-b-0 lg:border-r border-white/10 bg-black"
        >
          <img
            src={img}
            class="w-full h-full object-contain bg-black/50"
            alt={title}
          />
        </div>

        <div class="p-8 space-y-6 overflow-y-auto max-h-[60vh] lg:max-h-[80vh]">
          <div>
            <h3 class="text-3xl font-bold text-fab-orange mb-4">{title}</h3>

            {
              tags && (
                <div class="flex flex-wrap gap-2 mb-6">
                  {tags.map((tag) => (
                    <span class="badge badge-neutral border border-white/10 p-3">
                      {tag}
                    </span>
                  ))}
                </div>
              )
            }

            <div
              class="text-gray-300 leading-relaxed text-sm lg:text-base text-justify space-y-4 prose prose-invert prose-p:text-gray-300"
            >
              <div set:html={textoDescricao} />
            </div>
          </div>
        </div>
      </div>
    </div>
  </dialog>
</div>

<script>
  // Script otimizado para não duplicar listeners
  const buttons = document.querySelectorAll(".open-button");

  buttons.forEach((button) => {
    // Evita adicionar múltiplos listeners se o componente re-renderizar
    if (button.getAttribute("data-listener") === "true") return;
    button.setAttribute("data-listener", "true");

    button.addEventListener("click", (e) => {
      // Se clicar no dialog (backdrop) não faz nada no listener do botão
      if (e.target.tagName === "DIALOG") return;

      const modal = button.querySelector("dialog");
      const closeBtn = modal.querySelector(".close-button");

      if (modal) {
        modal.showModal();

        // Fecha ao clicar no botão X
        closeBtn.onclick = (ev) => {
          ev.stopPropagation(); // Impede que o clique propague para o card
          modal.close();
        };

        // Fecha ao clicar fora (backdrop)
        modal.onclick = (ev) => {
          if (ev.target === modal) {
            modal.close();
          }
        };
      }
    });
  });
</script>
