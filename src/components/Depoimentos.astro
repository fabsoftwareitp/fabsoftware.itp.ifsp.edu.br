---
// Depoimentos.astro
const { way, img, name, testimonial, video } = Astro.props;
---

<div
  class="relative w-[20rem] md:w-[24rem] h-[18rem] md:h-[20rem] flex-shrink-0 group"
>
  <div
    class="open-button w-full h-full cursor-pointer rounded-2xl border border-white/10 bg-[#0a0e26] p-6 flex flex-col justify-between transition-all duration-300 hover:border-fab-orange/50 hover:shadow-lg hover:shadow-fab-orange/10 hover:-translate-y-2"
  >
    <div class="text-fab-orange/20 text-4xl font-serif leading-none mb-2">
      “
    </div>

    <p
      class="text-gray-300 text-sm md:text-base leading-relaxed line-clamp-5 flex-grow"
    >
      {testimonial}
    </p>

    <div
      class="flex items-center justify-between mt-4 pt-4 border-t border-white/5"
    >
      <a
        href={way}
        class="flex items-center gap-3 group-hover:opacity-80 transition-opacity"
      >
        <img
          src={img}
          class="w-10 h-10 rounded-full object-cover border border-fab-orange/30"
          alt={name}
        />
        <div>
          <p class="text-white font-semibold text-sm">{name}</p>
          <span class="text-xs text-gray-500">Ver perfil</span>
        </div>
      </a>

      <div
        class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center group-hover:bg-red-600/20 group-hover:text-red-500 transition-colors text-gray-400"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="currentColor"><path d="M8 5v14l11-7z"></path></svg
        >
      </div>
    </div>
  </div>

  <dialog class="modal backdrop-blur-md bg-black/40">
    <div
      class="modal-box w-11/12 max-w-4xl bg-[#0a0e26] border border-fab-orange/30 text-white shadow-2xl p-0 overflow-hidden"
    >
      <div
        class="flex justify-between items-center p-4 border-b border-white/10 bg-white/5"
      >
        <h3 class="font-bold text-lg text-fab-orange">Depoimento de {name}</h3>
        <button
          class="close-button btn btn-sm btn-circle btn-ghost text-white hover:bg-white/10"
          >✕</button
        >
      </div>
      <div class="relative w-full pt-[56.25%] bg-black">
        <iframe
          class="absolute top-0 left-0 w-full h-full video-iframe"
          src={video}
          title="YouTube video player"
          frameborder="0"
          allowfullscreen></iframe>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop">
      <button class="close-backdrop">close</button>
    </form>
  </dialog>
</div>

<script is:inline>
  // Função auto-executável para evitar poluição do escopo global
  (function() {
    function initTestimonialModals() {
      var items = document.querySelectorAll(".group");
      
      for (var i = 0; i < items.length; i++) {
        var item = items[i];
        
        // Evita inicialização duplicada
        if (item.getAttribute("data-testimonial-init") === "true") continue;
        item.setAttribute("data-testimonial-init", "true");
        
        var openBtn = item.querySelector(".open-button");
        var modal = item.querySelector("dialog");
        var closeBtn = item.querySelector(".close-button");
        var backdropBtn = item.querySelector(".close-backdrop");
        var iframe = item.querySelector("iframe");
        var originalSrc = iframe ? iframe.src : "";
        
        if (openBtn && modal) {
          // Criar closure para manter referências corretas
          (function(openBtn, modal, closeBtn, backdropBtn, iframe, originalSrc) {
            var closeModal = function() {
              modal.close();
              if (iframe) iframe.src = originalSrc;
            };
            
            openBtn.addEventListener("click", function() {
              modal.showModal();
            });
            
            if (closeBtn) {
              closeBtn.addEventListener("click", function(e) {
                e.stopPropagation();
                closeModal();
              });
            }
            
            if (backdropBtn) {
              backdropBtn.addEventListener("click", function(e) {
                e.stopPropagation();
                closeModal();
              });
            }
          })(openBtn, modal, closeBtn, backdropBtn, iframe, originalSrc);
        }
      }
    }
    
    // Executar quando DOM estiver pronto
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initTestimonialModals);
    } else {
      initTestimonialModals();
    }
    
    // Re-executar após 500ms para elementos carregados dinamicamente
    setTimeout(initTestimonialModals, 500);
  })();
</script>
