---
const { way, img, name, position } = Astro.props;
---

<a
  href={way}
  class="glass-card rounded-xl p-6 text-center group relative overflow-hidden w-[18rem] h-[20rem] flex flex-col justify-center"
>
  <div
    class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-fab-orange to-yellow-500 transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300"
  >
  </div>
  <div class="avatar mb-6 justify-center">
    <div
      class="w-32 h-32 rounded-full ring-2 ring-white/10 group-hover:ring-fab-orange transition-all duration-300"
    >
      <img
        src={img}
        alt={name}
        class="w-full h-full object-cover rounded-full"
      />
    </div>
  </div>
  <h3 class="font-bold text-white text-lg mb-2">
    {name}
  </h3>
  <p class="text-sm text-gray-400 uppercase tracking-wider mb-4">
    {position}
  </p>
  <!-- Indicador de hover -->
  <div
    class="absolute bottom-4 right-4 opacity-0 group-hover:opacity-100 transition-all duration-300 translate-y-2 group-hover:translate-y-0"
  >
    <svg
      class="w-5 h-5 text-fab-orange"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
      aria-hidden="true"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M9 5l7 7-7 7"></path>
    </svg>
  </div>
</a>
<style>
  /* Glassmorphism Card */
  .glass-card {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 94, 30, 0.2);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
    /* Garantir que a borda seja bem definida */
    box-sizing: border-box;
    -webkit-box-sizing: border-box;
    -moz-box-sizing: border-box;
  }

  .glass-card:hover {
    border-color: rgba(255, 94, 30, 0.8);
    transform: translateY(-5px);
    box-shadow: 0 8px 40px rgba(255, 94, 30, 0.2);
  }

  /* Corrigir problemas de renderização */
  .glass-card * {
    box-sizing: border-box;
  }
</style>
