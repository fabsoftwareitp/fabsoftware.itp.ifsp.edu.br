---
import { STATISTICS } from "../constants/content";

interface Props {
  statistics?: Array<{
    value: string;
    label: string;
  }>;
}

const { statistics = STATISTICS } = Astro.props;
---

<div class="flex gap-8 pt-4 border-t border-white/10">
  {
    statistics.map((stat) => (
      <div class="text-center sm:text-left">
        <span
          class="block text-3xl font-bold text-white"
          aria-label={`${stat.value} ${stat.label}`}
        >
          {stat.value}
        </span>
        <span class="text-xs text-fab-orange uppercase font-bold tracking-wide">
          {stat.label}
        </span>
      </div>
    ))
  }
</div>
