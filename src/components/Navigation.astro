---

---

<nav
  class="navbar top-0 z-50 px-4 lg:px-10 py-3 text-white transition-all duration-300 bg-[#020415]/80 backdrop-blur-md border-b border-white/5 font-sans"
>
  <div class="navbar-start">
    <a href="/" class="flex gap-3 items-center group">
      <img
        src="/logo-claro.svg"
        alt="logo oficial"
        class="w-8 h-8 group-hover:rotate-12 transition-transform duration-300"
      />
      <span
        class="text-xl font-bold tracking-wide group-hover:text-[#ff5e1e] transition-colors duration-300"
      >
        FabSoftware
      </span>
    </a>
  </div>

  <div class="navbar-end hidden lg:flex">
    <ul class="menu menu-horizontal px-1 text-sm font-semibold gap-2">
      <li>
        <a
          href="../membros"
          class="hover:text-[#ff5e1e] hover:bg-white/5 rounded-lg transition-colors"
        >
          Equipe
        </a>
      </li>
      <li>
        <a
          href="../projetos"
          class="hover:text-[#ff5e1e] hover:bg-white/5 rounded-lg transition-colors"
        >
          Projetos
        </a>
      </li>
      <li>
        <a
          href="../sobre"
          class="hover:text-[#ff5e1e] hover:bg-white/5 rounded-lg transition-colors"
        >
          Sobre
        </a>
      </li>
      <li>
        <a
          href="../processo-seletivo"
          class="relative hover:text-[#ff5e1e] hover:bg-white/5 rounded-lg transition-colors"
        >
          Processo Seletivo
          <span
            class="absolute -top-2 -right-2 bg-fab-orange text-white text-[9px] font-bold px-1.5 py-0.5 rounded-full leading-none animate-pulse shadow-md shadow-[#ff5e1e]/40"
          >
            Aberto
          </span>
        </a>
      </li>
      <li>
        <a
          href="https://github.com/fabsoftwareitp"
          target="_blank"
          class="btn btn-sm bg-[#ff5e1e] border-none text-white hover:bg-[#ff3d00] ml-4 px-6 rounded-full shadow-lg shadow-[#ff5e1e]/20"
        >
          GitHub
        </a>
      </li>
    </ul>
  </div>

  <div class="navbar-end lg:hidden">
    <div class="dropdown dropdown-end">
      <div
        tabindex="0"
        role="button"
        class="btn btn-ghost btn-circle text-white hover:bg-white/10"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h7"></path>
        </svg>
      </div>

      <ul
        tabindex="0"
        class="menu menu-lg dropdown-content mt-3 z-[1] p-2 shadow-2xl bg-[#0a0e26] rounded-xl w-52 border border-[#ff5e1e]/30 text-white"
      >
        <li>
          <a
            href="../membros"
            class="hover:text-[#ff5e1e] active:bg-[#ff5e1e]/20">Equipe</a
          >
        </li>
        <li>
          <a
            href="../projetos"
            class="hover:text-[#ff5e1e] active:bg-[#ff5e1e]/20">Projetos</a
          >
        </li>
        <li>
          <a href="../sobre" class="hover:text-[#ff5e1e] active:bg-[#ff5e1e]/20"
            >Sobre</a
          >
        </li>
        <li>
          <a
            href="../processo-seletivo"
            class="hover:text-[#ff5e1e] active:bg-[#ff5e1e]/20 flex items-center justify-between"
          >
            Processo Seletivo
            <span
              class="bg-fab-orange text-white text-[9px] font-bold px-1.5 py-0.5 rounded-full leading-none animate-pulse shadow-md shadow-[#ff5e1e]/40"
            >
              Aberto
            </span>
          </a>
        </li>
        <div class="divider my-1 border-white/10"></div>
        <li>
          <a
            href="https://github.com/fabsoftwareitp"
            target="_blank"
            class="text-[#ff5e1e] font-bold">GitHub</a
          >
        </li>
      </ul>
    </div>
  </div>
</nav>
