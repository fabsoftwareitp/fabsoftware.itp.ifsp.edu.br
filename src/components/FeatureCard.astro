---
interface Props {
  title: string;
  description: string;
  icon: "cloud" | "tool" | "users" | string;
}

const { title, description, icon } = Astro.props;

// Mapeamento de ícones SVG
const iconMap = {
  cloud: `<path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 5-5v-5a5 5 0 0 0-5-5Z"></path><circle cx="6" cy="6" r="3"></circle><circle cx="6" cy="18" r="3"></circle>`,
  tool: `<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path>`,
  users: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path>`,
};

const iconPath = iconMap[icon] || iconMap.cloud;
---

<article class="glass-card p-6 rounded-2xl flex items-center gap-6 group">
  <div
    class="w-12 h-12 rounded-full bg-fab-orange/20 flex items-center justify-center text-fab-orange group-hover:bg-fab-orange/30 transition-colors duration-300"
    aria-hidden="true"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <Fragment set:html={iconPath} />
    </svg>
  </div>
  <div>
    <h3 class="font-bold text-lg text-white mb-1">{title}</h3>
    <p class="text-sm text-gray-400">{description}</p>
  </div>
</article>

<style>
  /* Glassmorphism Card */
  .glass-card {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 94, 30, 0.2);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
  }

  .glass-card:hover {
    border-color: #ff5e1e;
    transform: translateY(-5px);
    box-shadow: 0 0 20px rgba(255, 94, 30, 0.15);
  }
</style>
