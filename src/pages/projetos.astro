---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Destaque from "../components/Destaque.astro";

// Obter todos os projetos
const projetos = await getCollection("projetos");

const pageTitle = "Projetos da Fábrica de Software";
---

<BaseLayout pageTitle={pageTitle}>
  <!-- Header da página -->
  <section class="py-16 bg-[#05081c]">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-5xl font-bold text-white mb-4">
        Nossos <span class="text-fab-orange">Projetos</span>
      </h1>
      <p class="text-gray-400 max-w-3xl mx-auto">
        A Fábrica de Software possui mais de <span
          class="text-fab-orange font-bold">{projetos.length} projetos</span
        > entre finalizados e em desenvolvimento. Conheça nossas soluções e parcerias
        que transformam ideias em realidade.
      </p>
    </div>
  </section>

  <!-- Seção principal de projetos -->
  <section class="py-16 px-4 bg-fab-bg relative">
    <!-- Background decorativo -->
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-gradient-to-r from-fab-orange/5 to-transparent rounded-full blur-[100px] -z-10"
      aria-hidden="true"
    >
    </div>

    <div class="container mx-auto">
      <!-- Grid de projetos -->
      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8"
        role="group"
        aria-label="Lista de todos os projetos"
      >
        {
          projetos.map((projeto) => (
            <Destaque
              title={projeto.data.title}
              img={projeto.data.imgs[0]}
              descricao={projeto.body}
              tags={projeto.data.tags}
              status={projeto.data.status}
              link={projeto.data.link}
              date={projeto.data.date}
              github={projeto.data.github}
            />
          ))
        }
      </div>

      <!-- Call to action para contribuições -->
      <div class="text-center mt-20 pt-16 border-t border-white/10">
        <h3 class="text-2xl md:text-3xl font-bold text-white mb-4">
          Quer contribuir com nossos projetos?
        </h3>
        <p class="text-gray-400 mb-8 max-w-2xl mx-auto">
          A Fábrica de Software está sempre aberta a colaborações. Entre em
          contato e descubra como você pode fazer parte dos nossos projetos.
        </p>
        <a
          href="/sobre"
          class="btn btn-outline border-fab-orange text-fab-orange hover:bg-fab-orange hover:text-white px-8 py-3 rounded-full text-lg transition-all duration-300 focus:ring-2 focus:ring-fab-orange focus:ring-offset-2 focus:ring-offset-fab-bg"
          aria-label="Saiba mais sobre como contribuir"
        >
          Saiba Mais
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
