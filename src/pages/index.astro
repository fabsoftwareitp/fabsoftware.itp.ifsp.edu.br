---
import { getCollection } from "astro:content";

import BaseLayout from "../layouts/BaseLayout.astro";
import Equipe from "../components/Equipe.astro";
import Destaque from "../components/Destaque.astro";
import Depoimentos from "../components/Depoimentos.astro";
import Membro from "../components/Membro.astro";

const membros = await getCollection("membros");
const equipe = membros.filter((membro) => membro.data.status);

const projetos = await Astro.glob("../content/projetos/*.md");
const destaques = projetos.filter((destaque) => destaque.frontmatter.destaque);

// const projetos = await getCollection('projetos');
// const destaques = projetos.filter((projeto) => projeto.data.destaque);

const depoimentos = membros.filter(
  (membro) => membro.data.testimonial.discriminant
);

const pageTitle = "Fábrica de Software";
---

<BaseLayout pageTitle={pageTitle}>
  <!--HERO -->
  <div
    class="hero min-h-screen bg-hero-pattern flex items-center justify-center text-center px-4"
  >
    <div class="max-w-5xl animate-fade-in-up space-y-6">
      <div
        class="inline-block px-4 py-1 rounded-full border border-fab-orange/30 bg-fab-orange/10 text-fab-orange text-xs font-bold tracking-wider mb-4 uppercase"
      >
        IFSP Câmpus Itapetininga
      </div>

      <h1 class="text-5xl md:text-6xl font-bold text-white leading-tight">
        Transformando aprendizado&nbsp;em <br />
        <span class="text-gradient">soluções reais</span>
      </h1>

      <p
        class="text-lg md:text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed"
      >
        Um laboratório onde alunos aprendem na prática, desenvolvendo soluções
        reais que ajudam a comunidade e o campus.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
        <a
          href="#projetos"
          class="btn bg-fab-orange hover:bg-fab-orangeDark text-white border-none rounded-full px-8 h-12 min-h-0 text-base shadow-lg shadow-fab-orange/30"
        >
          Conheça nossos projetos
        </a>
        <a
          href="#sobre"
          class="btn btn-outline border-white/20 text-white hover:bg-white/10 hover:border-white rounded-full px-8 h-12 min-h-0 text-base"
        >
          Saiba mais
        </a>
      </div>
    </div>
  </div>

  <!--SOBRE -->

  <section id="sobre" class="py-24 px-4 container mx-auto relative">
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-fab-orange/10 rounded-full blur-[100px] -z-10"
    >
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div class="space-y-6">
        <h2 class="text-3xl md:text-4xl font-bold">
          Mais do que código, <br />
          <span class="text-fab-orange">desenvolvemos carreiras.</span>
        </h2>
        <p class="text-gray-400 leading-relaxed text-justify">
          Desde 2019, a Fábrica de Software atua como uma ponte entre a sala de
          aula e o mercado de trabalho.
          <br /><br />
          Nossos alunos não apenas "escrevem código"; eles gerenciam projetos, lidam
          com prazos reais, utilizam metodologias ágeis e entregam produtos que impactam
          a comunidade interna e externa do IFSP.
        </p>

        <div class="flex gap-8 pt-4 border-t border-white/10">
          <div>
            <span class="block text-3xl font-bold text-white">16+</span>
            <span class="text-xs text-fab-orange uppercase font-bold"
              >Projetos</span
            >
          </div>
          <div>
            <span class="block text-3xl font-bold text-white">27+</span>
            <span class="text-xs text-fab-orange uppercase font-bold"
              >Talentos Formados</span
            >
          </div>
        </div>
      </div>

      <div class="flex flex-col gap-5">
        <div class="glass-card p-6 rounded-2xl flex items-center gap-6">
          <div
            class="w-12 h-12 rounded-full bg-fab-orange/20 flex items-center justify-center text-fab-orange"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 5-5v-5a5 5 0 0 0-5-5Z"
              ></path>
              <circle cx="6" cy="6" r="3"></circle>
              <circle cx="6" cy="18" r="3"></circle>
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-lg text-white">Domínio Multi-Stack</h3>
            <p class="text-sm text-gray-500">Fullstack, Mobile e Cloud.</p>
          </div>
        </div>

        <div class="glass-card p-6 rounded-2xl flex items-center gap-6">
          <div
            class="w-12 h-12 rounded-full bg-fab-orange/20 flex items-center justify-center text-fab-orange"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"
              >
              </path>
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-lg text-white">Resolução de Problemas</h3>
            <p class="text-sm text-gray-500">
              Desafios reais para clientes reais.
            </p>
          </div>
        </div>

        <div class="glass-card p-6 rounded-2xl flex items-center gap-6">
          <div
            class="w-12 h-12 rounded-full bg-fab-orange/20 flex items-center justify-center text-fab-orange"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
              <circle cx="9" cy="7" r="4"></circle>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-lg text-white">Metodologias Ágeis</h3>
            <p class="text-sm text-gray-500">
              Scrum, Kanban e trabalho em equipe.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!--EQUIPE -->
  <section id="equipe" class="py-24 px-4 bg-[#05081c]">
    <div class="container mx-auto">
      <div
        class="flex flex-col md:flex-row justify-between items-end mb-12 gap-4"
      >
        <div>
          <h2 class="text-3xl font-bold text-white">
            Nossa <span class="text-fab-orange">Equipe</span>
          </h2>
          <p class="text-gray-400 mt-2">
            Mentes brilhantes por trás do código.
          </p>
        </div>
        <div class="hidden md:block h-1 flex-1 bg-white/5 mx-8 rounded-full">
        </div>
        <a href="#" class="text-sm text-fab-orange font-bold hover:underline"
          >Ver todos os membros -></a
        >
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {
          equipe.map((membro) => (
            <Equipe
              way={"/membros/" + membro.slug}
              name={membro.data.name}
              img={membro.data.avatar}
              position={membro.data.position}
            />
          ))
        }
      </div>
    </div>
  </section>

  <section class="py-4 relative bg-[#050714] reveal">
    <div class="container mx-auto px-4 mb-12 text-center">
      <h2 class="text-3xl md:text-5xl font-bold text-white mb-4 mt-16">
        O que dizem os <span class="text-fab-orange">Membros</span>
      </h2>
      <p class="text-gray-400">
        Histórias de quem passou pela Fábrica de Software
      </p>
    </div>

    <div class="relative w-full max-w-[100vw] overflow-hidden mask-gradient">
      <div class="flex w-max gap-8 py-10 animate-marquee hover:pause">
        {
          depoimentos.map((depoimento) => (
            <Depoimentos
              way={"/membros/" + depoimento.slug}
              name={depoimento.data.name}
              img={depoimento.data.avatar}
              testimonial={depoimento.data.testimonial.value.depoimento}
              video={depoimento.data.testimonial.value.video}
            />
          ))
        }

        <div class="flex gap-8" aria-hidden="true">
          {
            depoimentos.map((depoimento) => (
              <Depoimentos
                way={"/membros/" + depoimento.slug}
                name={depoimento.data.name}
                img={depoimento.data.avatar}
                testimonial={depoimento.data.testimonial.value.depoimento}
                video={depoimento.data.testimonial.value.video}
              />
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <style>
    /* Utilitário para pausar animação */
    .hover\:pause:hover {
      animation-play-state: paused;
    }

    /* Animação da Esteira */
    .animate-marquee {
      /* Ajuste o tempo (60s) para controlar a velocidade */
      animation: marquee 60s linear infinite;
    }

    /* A animação move a esteira até -50%.
       Como temos 2 grupos idênticos, quando chega em -50% (final do grupo 1),
       ele volta instantaneamente para 0% (começo do grupo 1),
       que é visualmente idêntico ao começo do grupo 2.
    */
    @keyframes marquee {
      0% {
        transform: translateX(0);
      }
      100% {
        transform: translateX(-50%);
      }
    }

    /* Fade lateral usando mask-image (funciona na maioria dos navegadores modernos) */
    .mask-gradient {
      mask-image: linear-gradient(
        to right,
        transparent,
        black 10%,
        black 90%,
        transparent
      );
      -webkit-mask-image: linear-gradient(
        to right,
        transparent,
        black 10%,
        black 90%,
        transparent
      );
    }

    /* AJUSTE PARA MOBILE (Opcional)
       Se quiser scroll manual no celular em vez de animação automática:
    */
    @media (max-width: 768px) {
      .animate-marquee {
        animation: none;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        width: 100%; /* Volta a ocupar 100% da tela */
        padding-left: 1rem; /* Padding lateral no mobile */
        padding-right: 1rem;
      }

      /* Esconde a duplicata no mobile para não ficar estranho */
      .animate-marquee > div[aria-hidden="true"] {
        display: none;
      }

      /* Garante snap no card */
      .animate-marquee > :global(div) {
        scroll-snap-align: center;
      }
    }
  </style>

  <!--PROJETOS -->
  <section id="projetos" class="py-16 px-4 container mx-auto reveal">
    <div class="text-center mb-16 space-y-4">
      <h2 class="text-3xl md:text-5xl font-bold mb-4 text-white">
        Projetos da <span class="text-fab-orange">Fábrica</span>
      </h2>

      <p class="max-w-3xl mx-auto text-gray-400 text-lg leading-relaxed">
        A Fábrica de Software possui mais de <a
          href="/projetos/"
          class="text-fab-orange hover:underline font-bold"
          >{projetos.length} projetos</a
        > entre finalizados e em desenvolvimento. Dentre os projetos, temos internos
        como o <span class="text-gray-200 font-semibold">SGE</span> e parcerias com
        a Prefeitura como o <span class="text-gray-200 font-semibold">SVSA</span
        > e <span class="text-gray-200 font-semibold">Consultório na Rua</span>.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        destaques.map((destaque) => (
          <Destaque
            title={destaque.frontmatter.title}
            img={destaque.frontmatter.imgs}
            descricao={destaque.compiledContent()}
            tags={destaque.frontmatter.tags}
            status={destaque.frontmatter.status}
          />
        ))
      }
    </div>

    <div class="flex justify-center mt-16">
      <a
        href="./projetos"
        class="btn btn-outline border-fab-orange text-fab-orange hover:bg-fab-orange hover:text-white px-8 rounded-full normal-case text-lg"
      >
        Ver todos os projetos
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .reveal {
    position: relative;
    transform: translateY(150px);
    opacity: 0;
    transition: 1s all ease;
  }
  .reveal.active {
    transform: translateY(0);
    opacity: 1;
    text: black;
  }
  body {
    background-color: #020415;
    color: #f8fafc;
  }

  /* Gradiente de Texto Moderno */
  .text-gradient {
    background: linear-gradient(to right, #ff5e1e, #ff9100);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  /* Glassmorphism Card */
  .glass-card {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 94, 30, 0.2);
    /* Borda laranja bem sutil */
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
  }

  .glass-card:hover {
    border-color: #ff5e1e;
    transform: translateY(-5px);
    box-shadow: 0 0 20px rgba(255, 94, 30, 0.15);
  }
</style>

<script is:inline>
  function reveal() {
    var reveals = document.querySelectorAll(".reveal");

    for (var i = 0; i < reveals.length; i++) {
      var windowHeight = window.innerHeight;
      var elementTop = reveals[i].getBoundingClientRect().top;
      var elementVisible = 150;

      if (elementTop < windowHeight - elementVisible) {
        reveals[i].classList.add("active");
      } else {
        reveals[i].classList.remove("active");
      }
    }
  }

  window.addEventListener("scroll", reveal);
</script>
