---
import { getCollection } from "astro:content";

import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import AboutSection from "../components/AboutSection.astro";
import TeamSection from "../components/TeamSection.astro";
import TestimonialCarousel from "../components/TestimonialCarousel.astro";
import ProjectsSection from "../components/ProjectsSection.astro";

const membros = await getCollection("membros");
const equipe = membros.filter((membro) => membro.data.status);

const projetos = await Astro.glob("../content/projetos/*.md");
const destaques = projetos.filter((destaque) => destaque.frontmatter.destaque);

const depoimentos = membros.filter(
  (membro) => membro.data.testimonial.discriminant
);

const pageTitle = "Fábrica de Software";
---

<BaseLayout pageTitle={pageTitle}>
  <!-- Seção Hero -->
  <Hero />

  <!-- Seção Sobre -->
  <AboutSection />

  <!-- Seção Equipe -->
  <TeamSection equipe={equipe} />

  <!-- Seção Depoimentos -->
  <TestimonialCarousel depoimentos={depoimentos} />

  <!-- Seção Projetos -->
  <ProjectsSection projetos={projetos} destaques={destaques} />
</BaseLayout>

<!-- Estilos globais -->
<style>
  @import "../styles/global.css";
</style>

<!-- Script para animação de reveal -->
<script>
  import "../scripts/reveal.js";
</script>
